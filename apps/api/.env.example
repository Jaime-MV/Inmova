# ─────────────────────────────────────────────────────────────
# INMOVA API - Plantilla de variables de entorno
# Copia este archivo como .env y completa los valores reales.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (local o Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/inmova

# Secreto para firmar los JWT
JWT_SECRET=cambia_este_valor_en_produccion

# Puerto del servidor Express
PORT=3000
