console.log('\n--- Consulta Demo: Buscando inmuebles con texto "reformado" en Chamberí: ---');
const resultadosBusqueda = db.inmuebles.find({
  $text: { $search: 'reformado' }
}, {
  referenciaInterna: 1,
  precioVenta: 1,
  zona: 1,
  score: { $meta: "textScore" }
}).sort({
  score: { $meta: "textScore" }
}).toArray();

printjson(resultadosBusqueda);

