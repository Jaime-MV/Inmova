const resumen = {
  usuarios: db.usuarios.countDocuments(),
  inmuebles: db.inmuebles.countDocuments(),
  clientes: db.clientes.countDocuments(),
  visitas: db.visitas.countDocuments(),
  plantillas: db.plantillas.countDocuments(),
  contratos: db.contratos.countDocuments(),
